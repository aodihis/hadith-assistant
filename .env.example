DATABASE_URL=postgres://postgres:postgres@localhost:5433/hadiths

SERVER_HOST=127.0.0.1
SERVER_PORT=3000

# The Rust API is excluded from Docker Compose by default, so `cargo run` can
# run it on the host. Uncomment this to include the API in Compose commands.
# COMPOSE_PROFILES=app

VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hadith_vectors
